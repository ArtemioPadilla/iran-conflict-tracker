---
import type { Claim } from '../../lib/schemas';

interface Props {
  claims: Claim[];
}

const { claims } = Astro.props;
---
<section class="section fade-in" id="sec-contested">
  <div class="section-header">
    <span class="section-num">06</span>
    <h2 class="section-title">Contested Claims Matrix</h2>
  </div>
  <div class="claims-list">
    {claims.map(c => (
      <div class="claim-card">
        <div class="claim-question">{c.question}</div>
        <div class="claim-side">
          <div class="claim-side-label a">Source A: {c.sideA.label}</div>
          <div class="claim-side-text">{c.sideA.text}</div>
        </div>
        <div class="claim-side">
          <div class="claim-side-label b">Source B: {c.sideB.label}</div>
          <div class="claim-side-text">{c.sideB.text}</div>
        </div>
        <div class="claim-resolution">&#9878; RESOLUTION: {c.resolution}</div>
      </div>
    ))}
  </div>
</section>
